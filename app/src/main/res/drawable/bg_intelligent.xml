<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/background_intelligent" />
        </shape>
    </item>
    <item
        android:top="0dp"
        android:left="0dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#40FFE082"
                android:centerColor="#20FFCA28"
                android:endColor="#10FFA000"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
